<IfModule mod_mime.c>
    # favicon.ico je PNG kopie značky (prohlížeče očekávají cestu /favicon.ico)
    <Files "favicon.ico">
        ForceType image/png
    </Files>
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>
