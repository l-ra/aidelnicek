<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Route /admin and /admin/ through the PHP router.
    # Without this rule the rewrite engine skips the request because
    # public/admin/ is a real directory (!-d condition below), causing Apache
    # to serve the directory directly and return 403 Forbidden.
    RewriteRule ^admin/?$ index.php [QSA,L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>
